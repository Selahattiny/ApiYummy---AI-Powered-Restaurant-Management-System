@model GetWhyChooseYummyByIdDto
@{
    ViewData["Title"] = "UpdateWhyChooseYummy";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Neden Bizi Seçmelisiniz Güncelleme Sayfası</h4>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <input type="hidden" asp-asp-for="ServiceId"/>
                            <label>Başlık</label>
                            <input type="text" asp-for="Title" form-control" />
                            <br />
                            <label>Açıklama</label>
                            <input type="text" asp-for="Description" form-control" />
                            <br />
                            <label>İkon Url</label>
                            <input type="text" asp-for="IconUrl" form-control" />
