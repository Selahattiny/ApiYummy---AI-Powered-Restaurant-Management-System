@model GetWhyChooseYummyByIdDto
@{
    ViewData["Title"] = "UpdateWhyChooseYummy";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Neden Bizi Seçmelisiniz Güncelleme Sayfası</h4>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <input type="hidden" asp-for="ServiceId" />

                            <div class="form-group">
                                <label>Başlık</label>
                                <input type="text" asp-for="Title" class="form-control" />
                            </div>

                            <div class="form-group">
                                <label>Açıklama</label>
                                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            </div>

                            <div class="form-group">
                                <label>İkon Url</label>
                                <input type="text" asp-for="IconUrl" class="form-control" />
                            </div>

                            <br />
                            <button type="submit" class="btn btn-success">Alanı Güncelle</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>