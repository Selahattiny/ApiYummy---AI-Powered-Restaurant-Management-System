@model CreateChefDto
@{
    ViewData["Title"] = "CreateChef";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}


<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Yeni Şef Ekleme Sayfası</h4>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <label>Şef Adı Soyadı</label>
                            <input type="text" asp-for="NameSurname" class="form-control" />
                            <br />
                            <label>Şef Ünvanı/Başlık</label>
                            <input type="text" asp-for="Title" class="form-control" />
                            <br />
                            <label>Şef Açıklaması</label>
                            <input type="text" asp-for="Description" class="form-control" />
                            <br />
                            <label>Şef ImageURL</label>
                            <input type="text" asp-for="ImgUrl" class="form-control" />
                            <br />
                            <button class="btn btn-primary">Şefi kaydet</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>







